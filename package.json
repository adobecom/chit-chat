{
  "name": "chit-chat",
  "version": "1.0.0",
  "description": "Chrome side-panel extension for the Milo page-commenter annotation tool",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node build.mjs",
    "watch": "node build.mjs --watch",
    "icons": "node scripts/make-icons.mjs",
    "package": "npm run build && rm -f chit-chat-extension.zip && zip -rq chit-chat-extension.zip manifest.json sidepanel.html dist icons"
  },
  "dependencies": {
    "@react-spectrum/s2": "^1.4.0",
    "dompurify": "^3.4.12",
    "quill": "^2.0.3",
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@react-aria/optimize-locales-plugin": "*",
    "esbuild": "^0.25.0",
    "unplugin-parcel-macros": "*"
  },
  "overrides": {
    "react": "$react",
    "react-dom": "$react-dom"
  }
}
