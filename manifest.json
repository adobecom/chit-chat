{
  "manifest_version": 3,
  "name": "Chit Chat",
  "version": "1.0.0",
  "description": "Annotation overlay tool (internal). Toolbar click opens the side panel and injects the overlay.",

  "key": "",

  "permissions": ["sidePanel", "activeTab", "scripting", "storage", "tabs", "identity"],
  "host_permissions": [
    "https://milo-core-prod.adobe.io/*",
    "https://milo-core-stage.adobe.io/*",
    "https://ims-na1.adobelogin.com/*",
    "https://ims-na1-stg1.adobelogin.com/*"
  ],

  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },

  "action": {
    "default_title": "Chit Chat — open annotation panel",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "side_panel": {
    "default_path": "sidepanel.html"
  },

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
