{
  "manifest_version": 3,
  "name": "Chit Chat",
  "version": "1.0.0",
  "description": "Annotation overlay for AEM/DA pages. Toolbar click opens the side panel and injects the overlay.",

  "permissions": ["sidePanel", "activeTab", "scripting", "storage"],
  "host_permissions": ["https://milo-core-prod.adobe.io/*"],

  "externally_connectable": {
    "matches": ["https://milo-core-prod.adobe.io/*"]
  },

  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },

  "action": {
    "default_title": "Chit Chat — open annotation panel",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "side_panel": {
    "default_path": "sidepanel.html"
  },

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
